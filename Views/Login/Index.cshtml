 @model LoginModel
@{
    Layout = "_LayoutLoggedOut";
    ViewData["Title"] = "Login";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<form class="mt-3" asp-controller="Login" asp-action="Entry" method="post">
    <div class="mb-3">
        <label for="exampleInputEmail1" class="form-label">Email address</label>
        <input type="text" class="form-control" id="login" asp-for="Login">
    </div>
    <div class="mb-3">
        <label for="exampleInputPassword1" class="form-label">Password</label>
        <input type="password" class="form-control" id="password" asp-for="Password">
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>